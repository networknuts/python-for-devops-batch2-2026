[Unit]
Description=Sample API App
After=network.target

[Service]
User=fastapi
Group=fastapi

WorkingDirectory=/opt/fastapi-project
Environment="PATH=/opt/fastapi-project/venv/bin"

ExecStart=/opt/fastapi-project/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target